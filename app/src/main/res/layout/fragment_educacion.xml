<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fondo_base">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Educación y Comunidad"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/color_acento_primario"
            android:paddingHorizontal="20dp"
            android:paddingTop="20dp"
            android:paddingBottom="10dp"/>

        <com.google.android.material.tabs.TabLayout
            android:id="@+id/tabLayoutEducacion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/fondo_base"
            app:tabIndicatorColor="@color/color_acento_primario"
            app:tabSelectedTextColor="@color/color_acento_primario"
            app:tabMode="scrollable" />

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chipGroupMisPublicaciones"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="8dp"
            android:visibility="gone"
            app:singleSelection="true"
            app:selectionRequired="true">

            <com.google.android.material.chip.Chip
                android:id="@+id/chipMisArticulos"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mis Artículos"
                app:chipBackgroundColor="@color/selector_chip_bg"
                android:textColor="@color/selector_chip_text"
                app:chipStrokeWidth="0dp"
                android:checked="true" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipMisHilos"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mis Hilos"
                app:chipBackgroundColor="@color/selector_chip_bg"
                android:textColor="@color/selector_chip_text"
                app:chipStrokeWidth="0dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipMisMascotas"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mis Mascotas"
                app:chipBackgroundColor="@color/selector_chip_bg"
                android:textColor="@color/selector_chip_text"
                app:chipStrokeWidth="0dp" />

        </com.google.android.material.chip.ChipGroup>

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chipGroupComunidad"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="8dp"
            android:visibility="gone"
            app:singleSelection="true"
            app:selectionRequired="true">

            <com.google.android.material.chip.Chip
                android:id="@+id/chipComunidadArticulos"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Artículos"
                app:chipBackgroundColor="@color/selector_chip_bg"
                android:textColor="@color/selector_chip_text"
                app:chipStrokeWidth="0dp"
                android:checked="true" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipComunidadMascotas"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mascotas"
                app:chipBackgroundColor="@color/selector_chip_bg"
                android:textColor="@color/selector_chip_text"
                app:chipStrokeWidth="0dp" />
        </com.google.android.material.chip.ChipGroup>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvArticulos"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingBottom="80dp" />
        <LinearLayout
            android:id="@+id/layoutEmptyState"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:visibility="gone"
            android:padding="32dp">

            <ImageView
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:src="@drawable/huella"
                app:tint="#D0D0D0" />

            <TextView
                android:id="@+id/tvEmptyStateTitulo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="¡Vaya! Esto está muy tranquilo..."
                android:textAlignment="center"
                android:textColor="@color/black"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvEmptyStateDesc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Todavía no hay publicaciones aquí. ¡Sé el primero en animar la comunidad!"
                android:textAlignment="center"
                android:textColor="@color/grey"
                android:textSize="14sp" />
        </LinearLayout>

    </LinearLayout>

    <ProgressBar
        android:id="@+id/pbCargando"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone"
        android:indeterminateTint="@color/color_acento_primario" />

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAgregarArticulo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="24dp"
        android:src="@android:drawable/ic_input_add"
        app:tint="@color/white"
        app:backgroundTint="@color/color_acento_primario"
        android:visibility="gone"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>