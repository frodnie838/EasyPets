<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="10dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp"
    app:strokeWidth="0dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/white">

        <ImageView
            android:id="@+id/ivIconoArticulo"
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:scaleType="centerCrop"
            android:src="@drawable/consejos"
            android:background="#F5F5F5"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvAutorArticulo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Por: Autor"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/color_acento_primario"/>

                <TextView
                    android:id="@+id/tvTiempoArticulo"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text=" • Hace 2h"
                    android:textSize="12sp"
                    android:textColor="#9E9E9E"
                    android:layout_marginStart="4dp"/>

                <ImageButton
                    android:id="@+id/btnMenuArticulo"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_more_vert"
                    android:visibility="gone"
                    app:tint="@color/grey" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvTituloArticulo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Título del artículo"
                android:textSize="19sp"
                android:textStyle="bold"
                android:textColor="@color/black"
                android:layout_marginTop="8dp"
                android:maxLines="2"
                android:ellipsize="end"/>

            <TextView
                android:id="@+id/tvDescripcionArticulo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Una breve descripción para enganchar al lector con el contenido de la publicación..."
                android:textSize="14sp"
                android:textColor="#616161"
                android:layout_marginTop="6dp"
                android:maxLines="3"
                android:ellipsize="end"
                android:lineSpacingExtra="3dp"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#EEEEEE"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="12dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Leer artículo completo"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#9E9E9E" />

                <ImageButton
                    android:id="@+id/btnLikeArticulo"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_heart_outline"
                    app:tint="@color/color_acento_primario"
                    android:scaleType="fitCenter"/>

                <TextView
                    android:id="@+id/tvLikeCountArticulo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="14sp"
                    android:layout_marginStart="6dp"
                    android:textStyle="bold"
                    android:textColor="#757575" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>