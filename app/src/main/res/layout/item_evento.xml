<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:layout_marginHorizontal="4dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical"
        android:background="@color/white">

        <ImageView
            android:id="@+id/ivTipoEvento"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/calendario"
            app:tint="@color/color_acento_primario"
            android:layout_marginEnd="16dp"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvTituloEvento"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Título del Evento"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/black"/>

            <TextView
                android:id="@+id/tvDetalleEvento"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="10:30 - Veterinario"
                android:textSize="14sp"
                android:textColor="#757575"
                android:layout_marginTop="2dp"/>

            <TextView
                android:id="@+id/tvMascotaEvento"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🐾 Luna"
                android:textSize="13sp"
                android:textColor="@color/color_acento_primario"
                android:textStyle="bold"
                android:layout_marginTop="4dp"
                android:visibility="gone"/>
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>