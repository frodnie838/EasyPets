<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Base.Theme.EasyPets" parent="Theme.Material3.Light.NoActionBar">
        <item name="android:windowLightStatusBar">true</item>

        <item name="android:statusBarColor">@color/white</item>
    </style>

    <style name="Theme.EasyPets" parent="Base.Theme.EasyPets" />

    <style name="TemaCalendario" parent="Theme.AppCompat.Light">
        <item name="colorAccent">@color/color_acento_primario</item>
        <item name="colorPrimary">@color/color_acento_primario</item>
    </style>

    <style name="ShapeAppearanceOverlay.App.Circle" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <style name="TemaPickerVerde" parent="ThemeOverlay.MaterialComponents.MaterialCalendar">
        <item name="colorPrimary">@color/color_acento_primario</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorAccent">@color/color_acento_primario</item>
    </style>
    <style name="AlertDialogCustom" parent="Theme.MaterialComponents.Light.Dialog.Alert">
        <item name="android:windowBackground">@color/fondo_base</item>
        <item name="colorAccent">@color/color_acento_primario</item>
        <item name="android:textColorPrimary">@color/color_acento_primario</item>
        <item name="android:textColor">@android:color/black</item>
        <item name="android:textColorSecondary">@android:color/black</item>
        <item name="colorPrimary">@color/color_acento_primario</item>
        <item name="buttonBarPositiveButtonStyle">@style/BotonVerdeDialogo</item>
    </style>

    <style name="BotonVerdeDialogo" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:textColor">@color/color_acento_primario</item>
    </style>
</resources>